# ─────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES
# ─────────────────────────────────────────────────────────────
# This file is NEVER committed to Git (add .env to .gitignore)
# Copy this file, rename to .env, and fill in your keys
# ─────────────────────────────────────────────────────────────

# Ollama runs locally — no key needed!
# Just make sure Ollama is running: `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434

# ── Future: OpenAI (optional) ────────────────────────────────
OPENAI_API_KEY=your_openai_key_here

# ── Future: Groq (optional, free & fast!) ───────────────────
# Groq uses the same openai client, just different base_url
GROQ_API_KEY=your_groq_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
